# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database ----
MONGO_URI=mongodb://localhost:27017/sema

# ---- Security (در production حتما مقادیر قوی و یکتا بگذارید) ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
OTP_SECRET=change-me-otp-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# در production روی true بگذارید (نیازمند HTTPS)
COOKIE_SECURE=false

# ---- CORS ----
CLIENT_ORIGIN=http://localhost:3000

# ---- SMS ----
# providers: console | kavenegar
SMS_PROVIDER=console
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=sema-otp

# ---- Seed (ساخت مدیر اولیه) ----
SEED_ADMIN_PHONE=09120000000
SEED_ADMIN_FIRSTNAME=مدیر
SEED_ADMIN_LASTNAME=سیستم
